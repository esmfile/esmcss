{
	"name": "esmcss",
	"version": "0.2.14",
	"description": "Import .css.ts/.css.js functions & focused css helper classes from ES Modules using esbuild",
	"keywords": [
		"css",
		"esm",
		"esbuild"
	],
	"homepage": "https://github.com/esmfile/esmcss#readme",
	"bugs": {
		"url": "https://github.com/esmfile/esmcss/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/esmfile/esmcss.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-esmcss@briantakita.me"
	},
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"esmcss_esbuild_plugin",
		"var__css__replace"
	],
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {},
	"peerDependencies": {
		"esbuild": ">=0.23.1"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}
